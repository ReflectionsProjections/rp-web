{
  "name": "@rp/hype",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build:dependencies": "yarn workspaces foreach -Rt --from @rp/hype --exclude @rp/hype run build",
    "build": "yarn build:dependencies && vite build",
    "dev": "yarn build:dependencies && vite",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives",
    "verify": "yarn build && tsc --noEmit && yarn lint"
  },
  "dependencies": {
    "@rp/shared": "*",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "7.8.1"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/react": "^18.2.66",
    "@types/react-autocomplete": "^1.8.11",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "typescript": "^5.2.2",
    "vite": "^5.2.0"
  }
}